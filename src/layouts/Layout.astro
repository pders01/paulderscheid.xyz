---
import "../styles/global.css";

interface Props {
    title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="sitemap" href="/sitemap-index.xml" />
        <link rel="alternate" type="application/rss+xml" title="paul derscheid" href="/rss.xml" />
        <meta name="description" content="Paul Derscheid" />
        <title>{title}</title>
    </head>
    <body>
        <main>
            <slot />
        </main>
        <footer>
            <a href="/legal">/impressum</a>
            <a href="/privacy-policy">/datenschutz</a>
            <a href="/takedown">/takedown</a>
        </footer>
    </body>
</html>
